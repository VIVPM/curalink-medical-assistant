# ============================================================
# Curalink FastAPI orchestrator - environment template
# Copy to .env and fill in. NEVER commit .env.
# ============================================================

# --- Service config ---
PORT=8000

# --- LLM (Groq only for hackathon) ---
# Stub OllamaBackend exists for future offline fallback but is not implemented.
LLM_BACKEND=groq
LLM_MODEL=llama-3.1-8b-instant
GROQ_API_KEY=

# --- PubMed (NCBI E-utilities) ---
# NCBI_API_KEY is optional but strongly recommended:
#   without key -> 3 req/sec  (429 errors during demo)
#   with key    -> 10 req/sec (safe)
# Free signup: https://www.ncbi.nlm.nih.gov/account/
NCBI_API_KEY=
NCBI_EMAIL=
NCBI_TOOL=curalink

# --- OpenAlex (no key, polite User-Agent only) ---
OPENALEX_EMAIL=

# --- Pinecone (semantic memory layer) ---
# Index must be created with: dim=768, metric=cosine, name=curalink
# 768 matches pritamdeka/S-PubMedBert-MS-MARCO output size.
PINECONE_API_KEY=
PINECONE_INDEX=curalink
PINECONE_HOST=

# --- Embedding + reranking models (downloaded on first run, cached locally) ---
BIENCODER_MODEL=pritamdeka/S-PubMedBert-MS-MARCO
CROSS_ENCODER_MODEL=ncbi/MedCPT-Cross-Encoder
