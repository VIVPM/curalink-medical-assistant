# ============================================================
# Curalink frontend (React + Vite) - environment template
# Copy to .env and fill in. NEVER commit .env.
#
# CRITICAL: only VITE_* variables are exposed to the browser.
# NEVER put secrets (API keys, DB URIs) in this file - they
# will be bundled into the JavaScript and shipped to every user.
# ============================================================

# Base URL of the Express API (local dev default)
VITE_API_URL=http://localhost:5173
